# Copy to .env and fill in. Get these from Supabase → Project Settings → API.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
PORT=3000

# Optional: enables the "Generate with AI" button in the dictionary.
# Get one at https://console.anthropic.com → API keys. Without it, manual
# word entry still works; the Generate button just shows a notice.
ANTHROPIC_API_KEY=sk-ant-...
